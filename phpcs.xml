<?xml version="1.0"?>
<ruleset name="login-app">
    <description>PHP CodeSniffer configuration</description>

    <file>app</file>

    <exclude-pattern>temp/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>

    <config name="php_version" value="80200"/>

    <rule ref="PSR12"/>
</ruleset>
