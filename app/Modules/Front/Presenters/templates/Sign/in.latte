{block title}Přihlášení{/block}

{block content}
<div class="row justify-content-center">
	<div class="col-md-4">
		<div class="card shadow-sm">
			<div class="card-body p-4">
				<h1 class="card-title h4 mb-4">Přihlášení</h1>
				{control signInForm}
			</div>
		</div>
		<p class="text-center mt-3">
			Nemáte účet? <a n:href="up">Registrujte se</a>
		</p>
	</div>
</div>
{/block}
