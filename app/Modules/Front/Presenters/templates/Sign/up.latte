{block title}Registrace{/block}

{block content}
<div class="row justify-content-center">
	<div class="col-md-5">
		<div class="card shadow-sm">
			<div class="card-body p-4">
				<h1 class="card-title h4 mb-4">Registrace</h1>
				{control signUpForm}
			</div>
		</div>
		<p class="text-center mt-3">
			Máte již účet? <a n:href="in">Přihlaste se</a>
		</p>
	</div>
</div>
{/block}
