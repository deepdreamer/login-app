<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{ifset title}{include title} | {/ifset}Login App</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ublaboo-datagrid@1.8.0/assets/css/datagrid.min.css">
</head>
<body>
	<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
		<span class="navbar-brand">Login App</span>
		<div class="ms-auto d-flex align-items-center gap-3">
			<span class="text-light">
				{$user->getIdentity()->getData()['name']}
				{$user->getIdentity()->getData()['surname']}
				<span class="badge bg-secondary">{$user->getRoles()[0]}</span>
			</span>
			<a n:href=":Front:Sign:out" class="btn btn-outline-light btn-sm">Odhlásit se</a>
		</div>
	</nav>

	<div class="container mt-4">
		{foreach $flashes as $flash}
			<div class="alert alert-{$flash->type}">{$flash->message}</div>
		{/foreach}

		{include content}
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/js/netteForms.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/nette.ajax.js@2.4.0/nette.ajax.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/ublaboo-datagrid@1.8.0/assets/js/datagrid.min.js"></script>
	<script>
		$.nette.init();
	</script>
</body>
</html>
