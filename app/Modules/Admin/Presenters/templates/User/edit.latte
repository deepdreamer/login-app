{block title}Upravit uživatele{/block}

{block content}
<h1 class="mb-4">Upravit uživatele: {$editedUser->name} {$editedUser->surname}</h1>
<div class="row">
	<div class="col-md-6">
		<div class="card">
			<div class="card-body">
				{control editForm}
			</div>
		</div>
	</div>
</div>
<a n:href="default" class="btn btn-secondary mt-3">Zpět na seznam</a>
{/block}
